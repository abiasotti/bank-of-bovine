DATABASE_URL="postgresql://bob:bob_dev_password@localhost:5432/bank_of_bovine"
REDIS_URL="redis://localhost:6379"

# Must match the app's INTERNAL_API_SECRET (../.env) exactly.
INTERNAL_API_SECRET="generate-a-random-secret"

# Where the app is reachable for the order-evaluation trigger. When the
# worker runs via docker-compose.dev.yml against an app running on the
# host via `npm run dev`, this is http://host.docker.internal:3000. Inside
# the full docker-compose.yml stack, it's http://app:3000.
APP_INTERNAL_URL="http://host.docker.internal:3000"

# Quote provider: mock | finnhub
QUOTE_PROVIDER="mock"
FINNHUB_API_KEY=""

# Optional overrides (sensible defaults: 30000 for finnhub, 5000 for mock,
# and 7000 for order evaluation).
# QUOTE_POLL_INTERVAL_MS=30000
# ORDER_EVAL_INTERVAL_MS=7000
