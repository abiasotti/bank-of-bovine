DATABASE_URL="postgresql://bob:bob_dev_password@localhost:5432/bank_of_bovine?schema=public"

# Auth.js - generate with: openssl rand -base64 33
AUTH_SECRET="generate-a-random-secret"

# Shared secret the worker uses to call /api/internal/evaluate-orders.
# Must match INTERNAL_API_SECRET in worker/.env exactly.
INTERNAL_API_SECRET="generate-a-random-secret"

# Quote provider: mock | finnhub. Only used here for the on-demand
# single-symbol lookup path (looking up a brand-new ticker) - scheduled
# background polling is owned by the worker (see worker/.env.example),
# which needs this same value set there too.
QUOTE_PROVIDER="mock"

# Required when QUOTE_PROVIDER=finnhub. Free tier: https://finnhub.io/register
FINNHUB_API_KEY=""

# Redis pub/sub for live quote push (see lib/quotes/quoteEvents.ts).
# redis://localhost:6379 when running docker-compose.dev.yml's redis
# service locally; redis://redis:6379 inside the full docker-compose.yml
# stack's network.
REDIS_URL="redis://localhost:6379"
